---
const currentPath = Astro.url.pathname;
---

<nav id="main-nav" class="relative z-50 bg-paper transition-all duration-300">
  <div class="max-w-[1400px] mx-auto px-6 lg:px-10">
    <div class="flex items-center justify-between h-20">
      <!-- Logo -->
      <a href="/" class="flex items-center group">
        <span class="font-display text-2xl font-bold tracking-[0.15em] uppercase text-ink">LUMA</span>
        <span class="w-2 h-2 bg-hot-pink ml-1 mt-3 group-hover:bg-champagne transition-colors duration-300"></span>
      </a>

      <!-- Desktop Nav Links — fashion-brand style -->
      <div class="hidden md:flex items-center gap-12">
        <a href="/" class={`text-[11px] tracking-[0.3em] uppercase font-semibold transition-colors duration-300 hover:text-hot-pink ${currentPath === '/' ? 'text-hot-pink' : 'text-ink'}`}>Home</a>
        <a href="/services" class={`text-[11px] tracking-[0.3em] uppercase font-semibold transition-colors duration-300 hover:text-hot-pink ${currentPath === '/services' ? 'text-hot-pink' : 'text-ink'}`}>Services</a>
        <a href="/book" class={`text-[11px] tracking-[0.3em] uppercase font-semibold transition-colors duration-300 hover:text-hot-pink ${currentPath === '/book' ? 'text-hot-pink' : 'text-ink'}`}>Book</a>
      </div>

      <!-- CTA Button -->
      <a href="/book" class="hidden md:inline-flex items-center px-7 py-3 bg-hot-pink text-white text-[10px] tracking-[0.3em] uppercase font-bold hover:bg-ink transition-all duration-300">
        Book Now
      </a>

      <!-- Mobile Menu Button -->
      <button id="mobile-menu-btn" class="md:hidden flex flex-col gap-1.5 p-2" aria-label="Open menu">
        <span class="block w-7 h-0.5 bg-ink transition-all duration-300 origin-center"></span>
        <span class="block w-7 h-0.5 bg-ink transition-all duration-300"></span>
        <span class="block w-5 h-0.5 bg-ink transition-all duration-300 origin-center"></span>
      </button>
    </div>
  </div>

  <!-- Mobile Menu -->
  <div id="mobile-menu" class="md:hidden fixed inset-0 top-0 bg-ink -translate-x-full transition-transform duration-400 ease-in-out z-40">
    <div class="flex flex-col items-center justify-center gap-10 pt-24">
      <a href="/" class={`font-display text-4xl tracking-[0.1em] uppercase transition-colors duration-300 hover:text-hot-pink ${currentPath === '/' ? 'text-hot-pink' : 'text-paper'}`}>Home</a>
      <a href="/services" class={`font-display text-4xl tracking-[0.1em] uppercase transition-colors duration-300 hover:text-hot-pink ${currentPath === '/services' ? 'text-hot-pink' : 'text-paper'}`}>Services</a>
      <a href="/book" class={`font-display text-4xl tracking-[0.1em] uppercase transition-colors duration-300 hover:text-hot-pink ${currentPath === '/book' ? 'text-hot-pink' : 'text-paper'}`}>Book</a>
      <a href="/book" class="mt-6 inline-flex items-center px-10 py-4 bg-hot-pink text-white text-xs tracking-[0.3em] uppercase font-bold">Book Now</a>
    </div>
  </div>
</nav>

<script>
  const nav = document.getElementById('main-nav');
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  let menuOpen = false;

  btn?.addEventListener('click', () => {
    menuOpen = !menuOpen;
    const spans = btn.querySelectorAll('span');
    if (menuOpen) {
      menu?.classList.remove('-translate-x-full');
      menu?.classList.add('translate-x-0');
      spans[0].classList.add('rotate-45', 'translate-y-[4px]', 'bg-paper');
      spans[1].classList.add('opacity-0');
      spans[2].classList.add('-rotate-45', '-translate-y-[4px]', 'w-7', 'bg-paper');
    } else {
      menu?.classList.add('-translate-x-full');
      menu?.classList.remove('translate-x-0');
      spans[0].classList.remove('rotate-45', 'translate-y-[4px]', 'bg-paper');
      spans[1].classList.remove('opacity-0');
      spans[2].classList.remove('-rotate-45', '-translate-y-[4px]', 'w-7', 'bg-paper');
    }
  });
</script>
