---
const currentPath = Astro.url.pathname;
---

<nav id="main-nav" class="fixed top-0 left-0 right-0 z-50 bg-warm-white/95 backdrop-blur-sm transition-shadow duration-300">
  <div class="max-w-7xl mx-auto px-6 lg:px-8">
    <div class="flex items-center justify-between h-20">
      <!-- Logo -->
      <a href="/" class="flex items-center gap-0.5 group">
        <span class="font-serif text-3xl font-semibold tracking-wider text-rich-black">LUMA</span>
        <span class="w-2 h-2 rounded-full bg-gold mt-3 group-hover:scale-125 transition-transform duration-300"></span>
      </a>

      <!-- Desktop Nav Links -->
      <div class="hidden md:flex items-center gap-10">
        <a href="/" class={`text-sm tracking-widest uppercase font-medium transition-colors duration-300 hover:text-gold ${currentPath === '/' ? 'text-gold' : 'text-rich-black'}`}>Home</a>
        <a href="/services" class={`text-sm tracking-widest uppercase font-medium transition-colors duration-300 hover:text-gold ${currentPath === '/services' ? 'text-gold' : 'text-rich-black'}`}>Services</a>
        <a href="/book" class={`text-sm tracking-widest uppercase font-medium transition-colors duration-300 hover:text-gold ${currentPath === '/book' ? 'text-gold' : 'text-rich-black'}`}>Book</a>
      </div>

      <!-- CTA Button -->
      <a href="/book" class="hidden md:inline-flex items-center px-7 py-3 bg-rich-black text-warm-white text-xs tracking-widest uppercase font-medium rounded-full hover:shadow-[0_0_20px_rgba(212,168,83,0.4)] transition-all duration-300 hover:bg-rich-black/90">
        Book Now
      </a>

      <!-- Mobile Menu Button -->
      <button id="mobile-menu-btn" class="md:hidden flex flex-col gap-1.5 p-2" aria-label="Open menu">
        <span class="block w-6 h-0.5 bg-rich-black transition-all duration-300 origin-center"></span>
        <span class="block w-6 h-0.5 bg-rich-black transition-all duration-300"></span>
        <span class="block w-4 h-0.5 bg-rich-black transition-all duration-300 origin-center"></span>
      </button>
    </div>
  </div>

  <!-- Mobile Menu -->
  <div id="mobile-menu" class="md:hidden fixed inset-0 top-20 bg-warm-white/98 backdrop-blur-md -translate-x-full transition-transform duration-400 ease-in-out z-40">
    <div class="flex flex-col items-center justify-center gap-8 pt-20">
      <a href="/" class={`font-serif text-3xl tracking-wide transition-colors duration-300 hover:text-gold ${currentPath === '/' ? 'text-gold' : 'text-rich-black'}`}>Home</a>
      <a href="/services" class={`font-serif text-3xl tracking-wide transition-colors duration-300 hover:text-gold ${currentPath === '/services' ? 'text-gold' : 'text-rich-black'}`}>Services</a>
      <a href="/book" class={`font-serif text-3xl tracking-wide transition-colors duration-300 hover:text-gold ${currentPath === '/book' ? 'text-gold' : 'text-rich-black'}`}>Book</a>
      <a href="/book" class="mt-4 inline-flex items-center px-10 py-4 bg-rich-black text-warm-white text-sm tracking-widest uppercase font-medium rounded-full">Book Now</a>
    </div>
  </div>
</nav>

<script>
  const nav = document.getElementById('main-nav');
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  let menuOpen = false;

  window.addEventListener('scroll', () => {
    if (window.scrollY > 20) {
      nav?.classList.add('shadow-md', 'bg-warm-white');
      nav?.classList.remove('bg-warm-white/95');
    } else {
      nav?.classList.remove('shadow-md', 'bg-warm-white');
      nav?.classList.add('bg-warm-white/95');
    }
  });

  btn?.addEventListener('click', () => {
    menuOpen = !menuOpen;
    const spans = btn.querySelectorAll('span');
    if (menuOpen) {
      menu?.classList.remove('-translate-x-full');
      menu?.classList.add('translate-x-0');
      spans[0].classList.add('rotate-45', 'translate-y-[4px]');
      spans[1].classList.add('opacity-0');
      spans[2].classList.add('-rotate-45', '-translate-y-[4px]', 'w-6');
    } else {
      menu?.classList.add('-translate-x-full');
      menu?.classList.remove('translate-x-0');
      spans[0].classList.remove('rotate-45', 'translate-y-[4px]');
      spans[1].classList.remove('opacity-0');
      spans[2].classList.remove('-rotate-45', '-translate-y-[4px]', 'w-6');
    }
  });
</script>
