---
---

<footer class="bg-rich-black text-warm-white/80 pt-20 pb-8">
  <div class="max-w-7xl mx-auto px-6 lg:px-8">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12 lg:gap-8 pb-16 border-b border-white/10">
      <!-- About -->
      <div>
        <div class="flex items-center gap-0.5 mb-6">
          <span class="font-serif text-2xl font-semibold tracking-wider text-warm-white">LUMA</span>
          <span class="w-1.5 h-1.5 rounded-full bg-gold mt-2"></span>
        </div>
        <p class="text-sm leading-relaxed text-warm-white/60">
          Award-winning hair, skin, and beauty studio in Sydney's CBD. We've been helping you look and feel extraordinary since 2017.
        </p>
        <div class="flex items-center gap-1 mt-4 text-xs text-warm-white/40">
          <span>ABN 77 888 222 456</span>
        </div>
      </div>

      <!-- Opening Hours -->
      <div>
        <h4 class="font-serif text-lg text-gold mb-6">Opening Hours</h4>
        <ul class="space-y-2 text-sm">
          <li class="flex justify-between"><span>Tuesday – Wednesday</span><span class="text-warm-white/50">9am – 6pm</span></li>
          <li class="flex justify-between"><span>Thursday – Friday</span><span class="text-warm-white/50">9am – 8pm</span></li>
          <li class="flex justify-between"><span>Saturday</span><span class="text-warm-white/50">8am – 5pm</span></li>
          <li class="flex justify-between"><span>Sunday – Monday</span><span class="text-warm-white/50">Closed</span></li>
        </ul>
      </div>

      <!-- Quick Links -->
      <div>
        <h4 class="font-serif text-lg text-gold mb-6">Quick Links</h4>
        <ul class="space-y-3 text-sm">
          <li><a href="/" class="hover:text-gold transition-colors duration-300">Home</a></li>
          <li><a href="/services" class="hover:text-gold transition-colors duration-300">Services & Pricing</a></li>
          <li><a href="/book" class="hover:text-gold transition-colors duration-300">Book Online</a></li>
          <li><a href="/book#contact" class="hover:text-gold transition-colors duration-300">Contact Us</a></li>
        </ul>
      </div>

      <!-- Stay Connected -->
      <div>
        <h4 class="font-serif text-lg text-gold mb-6">Stay Connected</h4>
        <a href="https://www.instagram.com/lumahairbeauty" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 text-sm hover:text-gold transition-colors duration-300 mb-6">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
          <span>@lumahairbeauty</span>
        </a>
        <p class="text-sm text-warm-white/50 mb-3">Subscribe for exclusive offers</p>
        <form action="https://formspree.io/f/placeholder" method="POST" class="flex gap-2">
          <label for="footer-email" class="sr-only">Email address</label>
          <input type="email" id="footer-email" name="email" placeholder="Your email" required class="flex-1 px-4 py-2.5 bg-white/10 border border-white/10 rounded-full text-sm text-warm-white placeholder-warm-white/30 focus:outline-none focus:border-gold transition-colors duration-300" />
          <button type="submit" class="px-5 py-2.5 bg-gold text-rich-black text-xs tracking-wider uppercase font-semibold rounded-full hover:bg-gold/90 transition-colors duration-300">Subscribe</button>
        </form>
      </div>
    </div>

    <div class="pt-8 text-center text-xs text-warm-white/30">
      <p>&copy; 2017–2026 LUMA Hair & Beauty. All rights reserved.</p>
      <p class="mt-1">45 York Street, Sydney NSW 2000 &middot; 02 9555 6100 &middot; hello@lumahairbeauty.com.au</p>
    </div>
  </div>
</footer>
