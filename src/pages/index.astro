---
import Layout from '../layouts/Layout.astro';

const services = [
  { name: 'Hair', tagline: 'Leave the chair with colour that turns heads and a cut that feels unmistakably you — crafted by Sydney CBD\'s most in-demand artists', image: 'https://images.unsplash.com/photo-1560066984-138dadb4c035?w=800&h=600&fit=crop', alt: 'Expert hair cutting and styling at LUMA salon on York Street Sydney CBD' },
  { name: 'Skin', tagline: 'Reveal your healthiest, most radiant complexion with clinical-grade facials, peels, and LED therapy tailored to your skin', image: 'https://images.unsplash.com/photo-1570172619644-dfd03ed5d881?w=800&h=600&fit=crop', alt: 'Professional facial treatment at LUMA beauty salon Sydney' },
  { name: 'Nails', tagline: 'Treat yourself to a flawless gel manicure or luxurious pedicure — your moment of calm in the heart of the city', image: 'https://images.unsplash.com/photo-1604654894610-df63bc536371?w=800&h=600&fit=crop', alt: 'Professional gel manicure and nail art at LUMA Sydney CBD salon' },
  { name: 'Lashes & Brows', tagline: 'Wake up every morning looking effortlessly polished with lash extensions, lifts, and precision brow shaping', image: 'https://images.unsplash.com/photo-1583001931096-959e9a1a6223?w=800&h=600&fit=crop', alt: 'Beautiful lash extensions and brow shaping at LUMA Hair and Beauty Sydney' },
];

const team = [
  { name: 'Isabella Ferraro', role: 'Creative Director & Senior Stylist', years: 12, specialty: 'Known for lived-in balayage and editorial looks that turn heads on York Street and beyond', image: 'https://images.unsplash.com/photo-1580618672591-eb180b1a973f?w=600&h=750&fit=crop', alt: 'Isabella Ferraro, Creative Director and Senior Stylist at LUMA Hair and Beauty Sydney CBD' },
  { name: 'Aiden Park', role: 'Senior Colourist', years: 8, specialty: 'Sydney\'s go-to for flawless balayage and complex colour corrections — his blends are iconic', image: 'https://images.unsplash.com/photo-1506794778202-cad84cf45f1d?w=600&h=750&fit=crop', alt: 'Aiden Park, Senior Colourist at LUMA salon Sydney' },
  { name: 'Chloe Bennett', role: 'Stylist & Extensions Specialist', years: 6, specialty: 'Creates seamless, undetectable extensions using tape, micro-link, and hand-tied methods', image: 'https://images.unsplash.com/photo-1534528741775-53994a69daeb?w=600&h=750&fit=crop', alt: 'Chloe Bennett, hair extensions specialist at LUMA Hair and Beauty Sydney' },
  { name: 'Maya Singh', role: 'Skin Therapist', years: 7, specialty: 'Signature facials, clinical peels, and LED therapy — clients call her "the glow whisperer"', image: 'https://images.unsplash.com/photo-1573497019940-1c28c88b4f3e?w=600&h=750&fit=crop', alt: 'Maya Singh, Skin Therapist at LUMA beauty salon Sydney CBD' },
  { name: 'Liam Torres', role: 'Barber & Stylist', years: 5, specialty: 'Sharp fades, textured crops, and modern men\'s grooming — the city\'s best-kept secret', image: 'https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?w=600&h=750&fit=crop', alt: 'Liam Torres, Barber and men\'s stylist at LUMA salon Sydney CBD' },
];

const beforeAfter = [
  { before: 'https://images.unsplash.com/photo-1522337360788-8b13dee7a37e?w=600&h=800&fit=crop', after: 'https://images.unsplash.com/photo-1492106087820-71f1a00d2b11?w=600&h=800&fit=crop', caption: 'Balayage transformation by Aiden — flat box-dye lifted to sun-kissed, dimensional caramel in one session', beforeAlt: 'Before: flat brunette hair with visible box-dye colour at LUMA Sydney', afterAlt: 'After: dimensional caramel balayage with warm tones by LUMA colourists' },
  { before: 'https://images.unsplash.com/photo-1519699047748-de8e457a634e?w=600&h=800&fit=crop', after: 'https://images.unsplash.com/photo-1596178060671-7a80dc8059ea?w=600&h=800&fit=crop', caption: 'Colour correction by Aiden — stubborn brassiness removed and restored to a luminous icy platinum', beforeAlt: 'Before: brassy yellowish blonde hair needing colour correction', afterAlt: 'After: flawless icy platinum blonde by LUMA colour correction specialist Sydney' },
  { before: 'https://images.unsplash.com/photo-1526047932273-341f2a7631f9?w=600&h=800&fit=crop', after: 'https://images.unsplash.com/photo-1494790108377-be9c29b29330?w=600&h=800&fit=crop', caption: 'The big chop by Isabella — waist-length hair reimagined as a textured lob with soft curtain bangs', beforeAlt: 'Before: long waist-length hair before cut at LUMA salon', afterAlt: 'After: chic textured lob with curtain bangs cut by Isabella at LUMA Sydney' },
];

const reviews = [
  { stars: 5, quote: 'I walked into LUMA with a Pinterest board and zero hope. Isabella nailed the exact balayage I wanted — I genuinely gasped when she turned my chair around. Best salon in Sydney CBD, hands down.', name: 'Jess M.', service: 'Balayage & Cut' },
  { stars: 5, quote: 'Maya\'s signature facial completely transformed my skin. My pores are smaller, my tone is even, and three people at work asked what I\'d changed. Already booked my next monthly session.', name: 'Anna K.', service: 'Signature Facial' },
  { stars: 5, quote: 'I\'m incredibly particular about my colour — I\'ve been to six salons in Sydney. Aiden was the first colourist to match my reference photo perfectly. No brassiness, no compromise. I\'m a LUMA client for life.', name: 'Megan R.', service: 'Full Colour & Toner' },
  { stars: 5, quote: 'The espresso, the warm towels, the fact they actually listen — LUMA feels like a five-star experience on York Street. Liam gave me the best cut I\'ve ever had, and I walked back to Wynyard feeling incredible.', name: 'Lily T.', service: 'Cut & Style' },
];

const instagramImages = [
  { src: 'https://images.unsplash.com/photo-1595476108010-b4d1f102b1b1?w=600&h=600&fit=crop', alt: 'Effortless beachy waves styled at LUMA Hair and Beauty salon Sydney CBD' },
  { src: 'https://images.unsplash.com/photo-1633681926022-84c23e8cb2d6?w=600&h=600&fit=crop', alt: 'LUMA salon interior on York Street Sydney with warm lighting and modern decor' },
  { src: 'https://images.unsplash.com/photo-1495474472287-4d71bcdd2085?w=600&h=600&fit=crop', alt: 'Complimentary artisan coffee served to clients at LUMA Sydney CBD salon' },
  { src: 'https://images.unsplash.com/photo-1527799820374-dcf8d9d4a388?w=600&h=600&fit=crop', alt: 'Premium styling tools and products used at LUMA Hair and Beauty Sydney' },
  { src: 'https://images.unsplash.com/photo-1487412912498-0447578fcca8?w=600&h=600&fit=crop', alt: 'Behind the scenes with LUMA stylists at our Sydney CBD hair salon' },
  { src: 'https://images.unsplash.com/photo-1519699047748-de8e457a634e?w=600&h=600&fit=crop', alt: 'Stunning platinum blonde colour result by LUMA colourists in Sydney' },
];
---

<Layout title="Sydney CBD Hair Salon | LUMA Hair & Beauty" description="Walk out feeling like the best version of yourself. Award-winning hair, skin & beauty in Sydney CBD. Book your appointment at LUMA today.">

  <!-- Hero Section — Full-bleed editorial -->
  <section class="relative min-h-screen flex items-center bg-ink overflow-hidden">
    <!-- Background image with overlay -->
    <div class="absolute inset-0">
      <img
        src="https://images.unsplash.com/photo-1560066984-138dadb4c035?w=1200&h=900&fit=crop"
        alt="Luxurious LUMA salon interior with warm lighting and modern styling stations"
        class="w-full h-full object-cover opacity-40"
        loading="eager"
      />
      <div class="absolute inset-0 bg-gradient-to-r from-ink/90 via-ink/60 to-transparent"></div>
    </div>
    <span class="watermark -bottom-8 -right-4 text-paper">LUMA</span>

    <div class="relative max-w-[1400px] mx-auto px-6 lg:px-10 w-full py-32 lg:py-0">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <div class="lg:py-20">
          <div class="animate-slide-up">
            <span class="inline-flex items-center gap-3 mb-6">
              <span class="w-10 h-[2px] bg-hot-pink"></span>
              <span class="text-[10px] tracking-[0.4em] uppercase text-hot-pink font-bold">Est. 2017 · Sydney CBD</span>
            </span>
          </div>
          <h1 class="font-display text-5xl sm:text-6xl lg:text-8xl font-bold leading-[0.95] tracking-tight text-paper mb-8 animate-slide-up-delay-1">
            Walk Out<br />Feeling<br /><span class="italic text-hot-pink">Incredible</span>
          </h1>
          <p class="text-lg text-paper/60 max-w-lg mb-10 leading-relaxed animate-slide-up-delay-2">
            Award-winning hair, skin, and beauty in Sydney CBD. You deserve to look in the mirror and love what you see — we make that happen.
          </p>
          <div class="flex flex-wrap gap-4 animate-slide-up-delay-3">
            <a href="/book" class="btn-primary">
              Book Your Appointment
            </a>
            <a href="/services" class="inline-flex items-center px-10 py-4 border-2 border-paper/30 text-paper text-[11px] tracking-[0.25em] uppercase font-bold hover:border-hot-pink hover:text-hot-pink transition-all duration-300">
              Find Your Look
            </a>
          </div>
          <div class="mt-16 flex items-center gap-6 animate-fade-in">
            <div class="flex items-center gap-1">
              {Array.from({ length: 5 }).map(() => (
                <svg class="w-4 h-4 text-champagne" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
              ))}
            </div>
            <span class="text-xs text-paper/40 tracking-wider uppercase">200+ Five-Star Reviews</span>
          </div>
        </div>
        <div class="hidden lg:flex justify-end">
          <div class="scroll-indicator mt-auto">
            <svg class="w-5 h-5 text-hot-pink" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"/></svg>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Service Categories — Magazine editorial grid -->
  <section class="py-28 lg:py-40 bg-paper relative overflow-hidden">
    <span class="watermark top-4 right-0">Beauty</span>
    <div class="relative max-w-[1400px] mx-auto px-6 lg:px-10">
      <div class="flex flex-col lg:flex-row lg:items-end justify-between mb-16 reveal">
        <div>
          <span class="inline-flex items-center gap-3 mb-4">
            <span class="w-10 h-[2px] bg-hot-pink"></span>
            <span class="text-[10px] tracking-[0.4em] uppercase text-hot-pink font-bold">What We Do</span>
          </span>
          <h2 class="font-display text-5xl sm:text-6xl lg:text-7xl font-bold tracking-tight leading-[0.95]">Your Beauty,<br />Our Expertise</h2>
        </div>
        <a href="/services" class="mt-6 lg:mt-0 btn-outline text-[10px]">View All Services</a>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4">
        {services.map((service, i) => (
          <a href="/services" class={`reveal stagger-${i + 1} group relative overflow-hidden aspect-[3/4] cursor-pointer`}>
            <img
              src={service.image}
              alt={service.alt}
              class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
              loading="lazy"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-ink via-ink/40 to-transparent"></div>
            <!-- Gold border on hover -->
            <div class="absolute inset-0 border-2 border-transparent group-hover:border-champagne transition-colors duration-500"></div>
            <span class="absolute top-4 right-6 font-display text-7xl text-paper/5 font-black">0{i + 1}</span>
            <div class="absolute bottom-0 left-0 right-0 p-6">
              <div class="w-8 h-[2px] bg-hot-pink mb-3 group-hover:w-12 transition-all duration-500"></div>
              <h3 class="font-display text-2xl text-paper font-bold mb-2">{service.name}</h3>
              <p class="text-sm text-paper/60 leading-relaxed">{service.tagline}</p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Section divider -->
  <div class="divider-editorial"><span></span></div>

  <!-- Meet the Team — Editorial carousel -->
  <section class="py-28 lg:py-40 bg-blush relative overflow-hidden">
    <span class="watermark top-4 left-0">Team</span>
    <div class="relative max-w-[1400px] mx-auto px-6 lg:px-10">
      <div class="flex items-end justify-between mb-14">
        <div>
          <span class="inline-flex items-center gap-3 mb-4">
            <span class="w-10 h-[2px] bg-hot-pink"></span>
            <span class="text-[10px] tracking-[0.4em] uppercase text-hot-pink font-bold">The People</span>
          </span>
          <h2 class="font-display text-5xl sm:text-6xl font-bold tracking-tight leading-[0.95]">Meet Your<br />Stylists</h2>
        </div>
        <div class="hidden sm:flex gap-3">
          <button id="team-prev" class="w-12 h-12 border-2 border-ink/20 hover:border-hot-pink hover:bg-hot-pink hover:text-paper flex items-center justify-center transition-all duration-300" aria-label="Scroll team carousel left">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
          </button>
          <button id="team-next" class="w-12 h-12 border-2 border-ink/20 hover:border-hot-pink hover:bg-hot-pink hover:text-paper flex items-center justify-center transition-all duration-300" aria-label="Scroll team carousel right">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
          </button>
        </div>
      </div>
      <div id="team-carousel" class="team-carousel flex gap-5 overflow-x-auto scroll-smooth pb-4">
        {team.map((member) => (
          <div class="flex-shrink-0 w-72 group">
            <div class="relative overflow-hidden mb-5">
              <img
                src={member.image}
                alt={member.alt}
                class="w-72 h-[420px] object-cover transition-transform duration-700 group-hover:scale-105 grayscale group-hover:grayscale-0"
                loading="lazy"
              />
              <div class="absolute inset-0 bg-hot-pink/0 group-hover:bg-hot-pink/10 transition-colors duration-500"></div>
              <div class="absolute bottom-0 left-0 right-0 h-1 bg-hot-pink transform scale-x-0 group-hover:scale-x-100 transition-transform duration-500 origin-left"></div>
            </div>
            <h3 class="font-display text-xl font-bold mb-1">{member.name}</h3>
            <p class="text-xs text-hot-pink font-bold tracking-wider uppercase mb-1">{member.role}</p>
            <p class="text-xs text-ink/50">{member.years} years <span class="inline-block w-1 h-1 bg-hot-pink mx-1 align-middle"></span> {member.specialty}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Before/After Gallery — Dramatic dark section -->
  <section class="py-28 lg:py-40 bg-ink">
    <div class="max-w-[1400px] mx-auto px-6 lg:px-10">
      <div class="text-center mb-16 reveal">
        <span class="inline-flex items-center justify-center gap-3 mb-4">
          <span class="w-10 h-[2px] bg-hot-pink"></span>
          <span class="text-[10px] tracking-[0.4em] uppercase text-hot-pink font-bold">Real Results</span>
          <span class="w-10 h-[2px] bg-hot-pink"></span>
        </span>
        <h2 class="font-display text-5xl sm:text-6xl font-bold tracking-tight text-paper leading-[0.95]">Your Transformation<br />Awaits</h2>
      </div>
      <div class="grid md:grid-cols-3 gap-6">
        {beforeAfter.map((item, i) => (
          <div class={`reveal stagger-${i + 1}`}>
            <div class="ba-slider relative overflow-hidden aspect-[3/4]" data-slider={i} tabindex="0" role="slider" aria-label={`Before and after comparison: ${item.caption}`} aria-valuemin="0" aria-valuemax="100" aria-valuenow="50">
              <img src={item.after} alt={item.afterAlt} class="ba-after w-full h-full object-cover" loading="lazy" />
              <div class="ba-before" style="width: 50%;">
                <img src={item.before} alt={item.beforeAlt} style={`width: ${100}%; min-width: 100%;`} loading="lazy" />
              </div>
              <div class="ba-handle" style="left: 50%;"></div>
              <div class="absolute top-4 left-1/2 -translate-x-1/2 z-20 bg-hot-pink text-paper text-[9px] tracking-[0.3em] uppercase font-bold px-4 py-2">Slide to compare</div>
              <div class="absolute top-14 left-4 bg-paper text-ink text-[9px] font-bold tracking-[0.2em] uppercase px-3 py-1.5">Before</div>
              <div class="absolute top-14 right-4 bg-ink text-paper text-[9px] font-bold tracking-[0.2em] uppercase px-3 py-1.5">After</div>
            </div>
            <p class="mt-4 text-sm text-center text-paper/50 italic">{item.caption}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Reviews — Light section with dark cards -->
  <section class="py-28 lg:py-40 bg-paper relative overflow-hidden">
    <div class="absolute inset-0 opacity-[0.02]" style="background-image: url('https://images.unsplash.com/photo-1544161515-4ab6ce6db874?w=1600&h=900&fit=crop'); background-size: cover; background-position: center;"></div>
    <div class="relative max-w-[1400px] mx-auto px-6 lg:px-10">
      <div class="text-center mb-16 reveal">
        <span class="inline-flex items-center justify-center gap-3 mb-4">
          <span class="w-10 h-[2px] bg-hot-pink"></span>
          <span class="text-[10px] tracking-[0.4em] uppercase text-hot-pink font-bold">Testimonials</span>
          <span class="w-10 h-[2px] bg-hot-pink"></span>
        </span>
        <h2 class="font-display text-5xl sm:text-6xl font-bold tracking-tight leading-[0.95]">What Our<br />Clients Say</h2>
      </div>
      <div class="flex justify-center mb-10">
        <span class="inline-flex items-center gap-2 bg-ink text-paper text-[10px] tracking-[0.2em] uppercase font-bold px-5 py-2.5">
          <span class="text-champagne">&#9733;</span> 200+ Five-Star Reviews
        </span>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-5">
        {reviews.map((review, i) => (
          <div class={`reveal stagger-${i + 1} relative bg-ink p-8 border border-champagne/20 hover:border-hot-pink/40 transition-colors duration-300`}>
            <span class="absolute -top-3 left-6 font-display text-6xl text-hot-pink/10 leading-none">&ldquo;</span>
            <div class="flex gap-1 mb-4">
              {Array.from({ length: review.stars }).map(() => (
                <svg class="w-3.5 h-3.5 text-champagne" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
              ))}
            </div>
            <p class="text-sm leading-relaxed text-paper/60 mb-6 italic">"{review.quote}"</p>
            <div class="border-t border-paper/10 pt-4">
              <p class="font-display text-lg text-paper font-bold">— {review.name}</p>
              <p class="text-[10px] text-hot-pink tracking-[0.2em] uppercase font-bold">{review.service}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Newsletter — Blush section -->
  <section class="py-28 lg:py-36 bg-blush relative overflow-hidden">
    <div class="max-w-2xl mx-auto px-6 lg:px-10 text-center reveal relative">
      <div class="inline-flex items-center gap-2 bg-hot-pink text-paper text-[10px] tracking-[0.3em] uppercase font-bold px-5 py-2 mb-6">15% OFF</div>
      <h2 class="font-display text-5xl font-bold tracking-tight mb-4">Join the LUMA List</h2>
      <p class="text-ink/60 mb-10 max-w-md mx-auto">Treat yourself to 15% off your first visit, plus be the first to hear about seasonal offers and new treatments.</p>
      <form id="newsletter-form" action="https://formspree.io/f/placeholder" method="POST" class="flex flex-col sm:flex-row gap-3 max-w-md mx-auto">
        <label for="newsletter-email" class="sr-only">Email address</label>
        <input type="email" id="newsletter-email" name="email" placeholder="Your email address" required class="flex-1 px-6 py-4 bg-paper border-2 border-ink/10 text-sm focus:outline-none focus:border-hot-pink transition-colors duration-300" />
        <button type="submit" class="px-8 py-4 bg-hot-pink text-white text-[10px] tracking-[0.25em] uppercase font-bold hover:bg-ink transition-colors duration-300">Subscribe</button>
      </form>
    </div>
  </section>

  <!-- Instagram — Full-bleed strip -->
  <section class="bg-ink py-20 lg:py-28">
    <div class="max-w-[1400px] mx-auto px-6 lg:px-10">
      <div class="text-center mb-12 reveal">
        <h2 class="font-display text-4xl lg:text-5xl font-bold tracking-tight text-paper mb-3">Follow <span class="text-hot-pink italic">@lumahairbeauty</span></h2>
        <p class="text-sm text-paper/40">Your daily dose of hair and beauty inspiration from our Sydney CBD studio</p>
      </div>
    </div>
    <div class="full-bleed-strip h-48 sm:h-64 lg:h-80">
      {instagramImages.map((img) => (
        <a href="https://www.instagram.com/lumahairbeauty" target="_blank" rel="noopener noreferrer" class="relative overflow-hidden group">
          <img
            src={img.src}
            alt={img.alt}
            class="w-full h-full object-cover"
            loading="lazy"
          />
          <div class="absolute inset-0 bg-hot-pink/0 group-hover:bg-hot-pink/30 transition-colors duration-300 flex items-center justify-center">
