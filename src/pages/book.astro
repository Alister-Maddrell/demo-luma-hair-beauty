---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Book Your Visit — LUMA Hair & Beauty">

  <!-- SECTION 1 — Page Header -->
  <section class="pt-16 pb-12 bg-warm-white relative overflow-hidden bg-grid-pattern">
    <span class="watermark -top-4 left-0 opacity-[0.02]">Book</span>
    <div class="max-w-4xl mx-auto px-6 lg:px-8 text-center">
      <div class="badge-frosted text-gold mb-6">Online Booking</div>
      <span class="inline-flex items-center gap-2 mb-6">
        <span class="w-8 h-px bg-gold"></span>
        <span class="text-xs tracking-[0.3em] uppercase text-gold font-medium">Appointments</span>
        <span class="w-8 h-px bg-gold"></span>
      </span>
      <h1 class="font-serif text-5xl sm:text-6xl font-light tracking-wide mb-6">Book Your Visit</h1>
      <div class="w-12 h-0.5 bg-gold/40 mx-auto mt-4"></div>
      <p class="text-rich-black/60 max-w-xl mx-auto leading-relaxed">
        Choose your service, pick your stylist, and find a time that works. We'll confirm your appointment within the hour.
      </p>
    </div>
  </section>

  <!-- SECTION 2 — Booking Flow -->
  <section id="booking-section" class="pb-24 bg-warm-white relative crosshatch">
    <div class="max-w-4xl mx-auto px-6 lg:px-8">

      <!-- Progress Bar -->
      <div class="flex items-center justify-center mb-12">
        <div class="flex items-center">
          <div class="booking-dot w-10 h-10 rounded-full flex items-center justify-center text-sm font-semibold bg-gold text-white" data-dot="1">1</div>
          <div class="booking-line w-12 sm:w-20 h-0.5 bg-nude/30" data-line="1"></div>
          <div class="booking-dot w-10 h-10 rounded-full flex items-center justify-center text-sm font-semibold bg-nude/30 text-rich-black/40" data-dot="2">2</div>
          <div class="booking-line w-12 sm:w-20 h-0.5 bg-nude/30" data-line="2"></div>
          <div class="booking-dot w-10 h-10 rounded-full flex items-center justify-center text-sm font-semibold bg-nude/30 text-rich-black/40" data-dot="3">3</div>
          <div class="booking-line w-12 sm:w-20 h-0.5 bg-nude/30" data-line="3"></div>
          <div class="booking-dot w-10 h-10 rounded-full flex items-center justify-center text-sm font-semibold bg-nude/30 text-rich-black/40" data-dot="4">4</div>
        </div>
      </div>
      <div class="flex items-center justify-center mb-4">
        <div class="flex items-center">
          <span class="w-10 text-center text-[9px] tracking-wider uppercase text-rich-black/30">Service</span>
          <span class="w-12 sm:w-20"></span>
          <span class="w-10 text-center text-[9px] tracking-wider uppercase text-rich-black/30">Stylist</span>
          <span class="w-12 sm:w-20"></span>
          <span class="w-10 text-center text-[9px] tracking-wider uppercase text-rich-black/30">Time</span>
          <span class="w-12 sm:w-20"></span>
          <span class="w-10 text-center text-[9px] tracking-wider uppercase text-rich-black/30">Details</span>
        </div>
      </div>

      <!-- Step 1: Select Service -->
      <div id="step-1" style="display: block;">
        <h2 class="font-serif text-2xl text-center mb-2">Select Service</h2>
        <p class="text-sm text-center text-rich-black/50 mb-8">What would you like today?</p>
        <div class="grid sm:grid-cols-2 gap-4 max-w-2xl mx-auto">
          <button class="service-card gold-glow text-left p-6 rounded-3xl border-2 border-nude/30 hover:border-gold bg-white/50 transition-all duration-300 cursor-pointer" data-service="hair">
            <span class="text-3xl mb-3 block">&#9986;</span>
            <h3 class="font-serif text-xl mb-1">Hair</h3>
            <p class="text-xs text-rich-black/50">Cuts, colour, treatments & extensions</p>
          </button>
          <button class="service-card gold-glow text-left p-6 rounded-3xl border-2 border-nude/30 hover:border-gold bg-white/50 transition-all duration-300 cursor-pointer" data-service="skin">
            <span class="text-3xl mb-3 block">&#10024;</span>
            <h3 class="font-serif text-xl mb-1">Skin</h3>
            <p class="text-xs text-rich-black/50">Facials, peels & skin therapy</p>
          </button>
          <button class="service-card gold-glow text-left p-6 rounded-3xl border-2 border-nude/30 hover:border-gold bg-white/50 transition-all duration-300 cursor-pointer" data-service="nails">
            <span class="text-3xl mb-3 block">&#128133;</span>
            <h3 class="font-serif text-xl mb-1">Nails</h3>
            <p class="text-xs text-rich-black/50">Manicures, pedicures & nail art</p>
          </button>
          <button class="service-card gold-glow text-left p-6 rounded-3xl border-2 border-nude/30 hover:border-gold bg-white/50 transition-all duration-300 cursor-pointer" data-service="lashes">
            <span class="text-3xl mb-3 block">&#128065;&#65039;</span>
            <h3 class="font-serif text-xl mb-1">Lashes & Brows</h3>
            <p class="text-xs text-rich-black/50">Extensions, lifts, tints & shaping</p>
          </button>
        </div>
      </div>

      <!-- Step 2: Select Stylist -->
      <div id="step-2" style="display: none;">
        <button class="back-link text-sm text-rich-black/50 hover:text-gold transition-colors duration-300 mb-6 flex items-center gap-1 cursor-pointer">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
          Back
        </button>
        <h2 class="font-serif text-2xl text-center mb-2">Select Stylist</h2>
        <p class="text-sm text-center text-rich-black/50 mb-8">Who would you like to see?</p>
        <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 max-w-3xl mx-auto">
          <button class="stylist-card text-center p-4 rounded-3xl border-2 border-nude/30 hover:border-gold bg-white/50 transition-all duration-300 cursor-pointer" data-stylist="Isabella Ferraro">
            <img src="https://images.unsplash.com/photo-1580618672591-eb180b1a973f?w=300&h=400&fit=crop" alt="Isabella Ferraro" class="w-20 h-20 rounded-full mx-auto mb-3 object-cover" loading="lazy" />
            <h3 class="font-serif text-sm">Isabella Ferraro</h3>
            <p class="text-xs text-rich-black/40">Senior Stylist</p>
          </button>
          <button class="stylist-card text-center p-4 rounded-3xl border-2 border-nude/30 hover:border-gold bg-white/50 transition-all duration-300 cursor-pointer" data-stylist="Aiden Park">
            <img src="https://images.unsplash.com/photo-1506794778202-cad84cf45f1d?w=300&h=400&fit=crop" alt="Aiden Park" class="w-20 h-20 rounded-full mx-auto mb-3 object-cover" loading="lazy" />
            <h3 class="font-serif text-sm">Aiden Park</h3>
            <p class="text-xs text-rich-black/40">Senior Colourist</p>
          </button>
          <button class="stylist-card text-center p-4 rounded-3xl border-2 border-nude/30 hover:border-gold bg-white/50 transition-all duration-300 cursor-pointer" data-stylist="Chloe Bennett">
            <img src="https://images.unsplash.com/photo-1534528741775-53994a69daeb?w=300&h=400&fit=crop" alt="Chloe Bennett" class="w-20 h-20 rounded-full mx-auto mb-3 object-cover" loading="lazy" />
            <h3 class="font-serif text-sm">Chloe Bennett</h3>
            <p class="text-xs text-rich-black/40">Extensions Specialist</p>
          </button>
          <button class="stylist-card text-center p-4 rounded-3xl border-2 border-nude/30 hover:border-gold bg-white/50 transition-all duration-300 cursor-pointer" data-stylist="Maya Singh">
            <img src="https://images.unsplash.com/photo-1573497019940-1c28c88b4f3e?w=300&h=400&fit=crop" alt="Maya Singh" class="w-20 h-20 rounded-full mx-auto mb-3 object-cover" loading="lazy" />
            <h3 class="font-serif text-sm">Maya Singh</h3>
            <p class="text-xs text-rich-black/40">Skin Therapist</p>
          </button>
        </div>
      </div>

      <!-- Step 3: Select Date & Time -->
      <div id="step-3" style="display: none;">
        <button class="back-link text-sm text-rich-black/50 hover:text-gold transition-colors duration-300 mb-6 flex items-center gap-1 cursor-pointer">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
          Back
        </button>
        <h2 class="font-serif text-2xl text-center mb-2">Select Date & Time</h2>
        <p class="text-sm text-center text-rich-black/50 mb-8">Choose a time that works for you</p>
        <div class="max-w-2xl mx-auto">
          <div class="grid grid-cols-5 gap-3">
            <!-- Day headers -->
            <div class="text-center">
              <p class="text-xs text-rich-black/40 uppercase mb-1">Mon</p>
              <p class="font-serif text-lg">17</p>
              <p class="text-xs text-rich-black/40">Mar</p>
            </div>
            <div class="text-center">
              <p class="text-xs text-rich-black/40 uppercase mb-1">Tue</p>
              <p class="font-serif text-lg">18</p>
              <p class="text-xs text-rich-black/40">Mar</p>
            </div>
            <div class="text-center">
              <p class="text-xs text-rich-black/40 uppercase mb-1">Wed</p>
              <p class="font-serif text-lg">19</p>
              <p class="text-xs text-rich-black/40">Mar</p>
            </div>
            <div class="text-center">
              <p class="text-xs text-rich-black/40 uppercase mb-1">Thu</p>
              <p class="font-serif text-lg">20</p>
              <p class="text-xs text-rich-black/40">Mar</p>
            </div>
            <div class="text-center">
              <p class="text-xs text-rich-black/40 uppercase mb-1">Fri</p>
              <p class="font-serif text-lg">21</p>
              <p class="text-xs text-rich-black/40">Mar</p>
            </div>
            <!-- Time slots row 1: 9:00 AM -->
            <button class="time-slot py-2 rounded-xl border border-nude/30 bg-white/50 hover:border-gold text-xs text-rich-black/70 transition-all duration-300 cursor-pointer" data-time="Mon 17 — 9:00 AM">9:00 AM</button>
            <button class="time-slot py-2 rounded-xl border border-nude/30 bg-white/50 hover:border-gold text-xs text-rich-black/70 transition-all duration-300 cursor-pointer" data-time="Tue 18 — 9:00 AM">9:00 AM</button>
            <button class="time-slot py-2 rounded-xl border border-nude/30 bg-white/50 hover:border-gold text-xs text-rich-black/70 transition-all duration-300 cursor-pointer" data-time="Wed 19 — 9:00 AM">9:00 AM</button>
            <button class="time-slot py-2 rounded-xl border border-nude/30 bg-white/50 hover:border-gold text-xs text-rich-black/70 transition-all duration-300 cursor-pointer" data-time="Thu 20 — 9:00 AM">9:00 AM</button>
            <button class="time-slot py-2 rounded-xl border border-nude/30 bg-white/50 hover:border-gold text-xs text-rich-black/70 transition-all duration-300 cursor-pointer" data-time="Fri 21 — 9:00 AM">9:00 AM</button>
            <!-- Time slots row 2: 10:30 AM -->
            <button class="time-slot py-2 rounded-xl border border-nude/30 bg-white/50 hover:border-gold text-xs text-rich-black/70 transition-all duration-300 cursor-pointer" data-time="Mon 17 — 10:30 AM">10:30 AM</button>
            <button class="time-slot py-2 rounded-xl border border-nude/30 bg-white/50 hover:border-gold text-xs text-rich-black/70 transition-all duration-300 cursor-pointer" data-time="Tue 18 — 10:30 AM">10:30 AM</button>
            <button class="time-slot py-2 rounded-xl border border-nude/30 bg-white/50 hover:border-gold text-xs text-rich-black/70 transition-all duration-300 cursor-pointer" data-time="Wed 19 — 10:30 AM">10:30 AM</button>
            <button class="time-slot py-2 rounded-xl border border-nude/30 bg-white/50 hover:border-gold text-xs text-rich-black/70 transition-all duration-300 cursor-pointer" data-time="Thu 20 — 10:30 AM">10:30 AM</button>
            <button class="time-slot py-2 rounded-xl border border-nude/30 bg-white/50 hover:border-gold text-xs text-rich-black/70 transition-all duration-300 cursor-pointer" data-time="Fri 21 — 10:30 AM">10:30 AM</button>
            <!-- Time slots row 3: 1:00 PM -->
            <button class="time-slot py-2 rounded-xl border border-nude/30 bg-white/50 hover:border-gold text-xs text-rich-black/70 transition-all duration-300 cursor-pointer" data-time="Mon 17 — 1:00 PM">1:00 PM</button>
            <button class="time-slot py-2 rounded-xl border border-nude/30 bg-white/50 hover:border-gold text-xs text-rich-black/70 transition-all duration-300 cursor-pointer" data-time="Tue 18 — 1:00 PM">1:00 PM</button>
            <button class="time-slot py-2 rounded-xl border border-nude/30 bg-white/50 hover:border-gold text-xs text-rich-black/70 transition-all duration-300 cursor-pointer" data-time="Wed 19 — 1:00 PM">1:00 PM</button>
            <button class="time-slot py-2 rounded-xl border border-nude/30 bg-white/50 hover:border-gold text-xs text-rich-black/70 transition-all duration-300 cursor-pointer" data-time="Thu 20 — 1:00 PM">1:00 PM</button>
            <button class="time-slot py-2 rounded-xl border border-nude/30 bg-white/50 hover:border-gold text-xs text-rich-black/70 transition-all duration-300 cursor-pointer" data-time="Fri 21 — 1:00 PM">1:00 PM</button>
            <!-- Time slots row 4: 3:30 PM -->
            <button class="time-slot py-2 rounded-xl border border-nude/30 bg-white/50 hover:border-gold text-xs text-rich-black/70 transition-all duration-300 cursor-pointer" data-time="Mon 17 — 3:30 PM">3:30 PM</button>
            <button class="time-slot py-2 rounded-xl border border-nude/30 bg-white/50 hover:border-gold text-xs text-rich-black/70 transition-all duration-300 cursor-pointer" data-time="Tue 18 — 3:30 PM">3:30 PM</button>
            <button class="time-slot py-2 rounded-xl border border-nude/30 bg-white/50 hover:border-gold text-xs text-rich-black/70 transition-all duration-300 cursor-pointer" data-time="Wed 19 — 3:30 PM">3:30 PM</button>
            <button class="time-slot py-2 rounded-xl border border-nude/30 bg-white/50 hover:border-gold text-xs text-rich-black/70 transition-all duration-300 cursor-pointer" data-time="Thu 20 — 3:30 PM">3:30 PM</button>
            <button class="time-slot py-2 rounded-xl border border-nude/30 bg-white/50 hover:border-gold text-xs text-rich-black/70 transition-all duration-300 cursor-pointer" data-time="Fri 21 — 3:30 PM">3:30 PM</button>
          </div>
        </div>
      </div>

      <!-- Step 4: Your Details -->
      <div id="step-4" style="display: none;">
        <button class="back-link text-sm text-rich-black/50 hover:text-gold transition-colors duration-300 mb-6 flex items-center gap-1 cursor-pointer">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
          Back
        </button>
        <h2 class="font-serif text-2xl text-center mb-2">Your Details</h2>
        <p class="text-sm text-center text-rich-black/50 mb-8">Almost there — just a few details</p>
        <form id="booking-form" action="https://formspree.io/f/placeholder" method="POST" class="corner-brackets p-8 max-w-lg mx-auto space-y-4">
          <div>
            <label for="name" class="block text-xs tracking-wider uppercase text-rich-black/50 mb-1.5">Full Name</label>
            <input type="text" id="name" name="name" required class="w-full px-5 py-3 border border-nude/50 rounded-2xl text-sm focus:outline-none focus:border-gold transition-colors duration-300 bg-white/50" />
          </div>
          <div>
            <label for="email" class="block text-xs tracking-wider uppercase text-rich-black/50 mb-1.5">Email</label>
            <input type="email" id="email" name="email" required class="w-full px-5 py-3 border border-nude/50 rounded-2xl text-sm focus:outline-none focus:border-gold transition-colors duration-300 bg-white/50" />
          </div>
          <div>
            <label for="phone" class="block text-xs tracking-wider uppercase text-rich-black/50 mb-1.5">Phone</label>
            <input type="tel" id="phone" name="phone" required class="w-full px-5 py-3 border border-nude/50 rounded-2xl text-sm focus:outline-none focus:border-gold transition-colors duration-300 bg-white/50" />
          </div>
          <div>
            <label for="notes" class="block text-xs tracking-wider uppercase text-rich-black/50 mb-1.5">Notes (optional)</label>
            <textarea id="notes" name="notes" rows="3" class="w-full px-5 py-3 border border-nude/50 rounded-2xl text-sm focus:outline-none focus:border-gold transition-colors duration-300 bg-white/50 resize-none" placeholder="Anything we should know?"></textarea>
          </div>
          <input type="hidden" name="service" id="hidden-service" />
          <input type="hidden" name="stylist" id="hidden-stylist" />
          <input type="hidden" name="time" id="hidden-time" />
          <button type="submit" class="w-full py-4 bg-gold text-white text-xs tracking-[0.2em] uppercase font-semibold rounded-full hover:bg-gold/90 transition-colors duration-300 mt-4 cursor-pointer">
            Confirm Booking
          </button>
        </form>
        <div id="success-message" style="display: none;" class="max-w-lg mx-auto text-center py-12">
          <div class="w-16 h-0.5 bg-gold/30 mx-auto mb-6"></div>
          <div class="w-16 h-16 rounded-full bg-gold/10 flex items-center justify-center mx-auto mb-6">
            <svg class="w-8 h-8 text-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
          </div>
          <h3 class="font-serif text-2xl mb-3">Booking Request Sent!</h3>
          <p class="text-sm text-rich-black/60">We'll confirm within the hour.</p>
        </div>
      </div>

      <!-- SECTION 3 — Cancellation Policy -->
      <div class="mt-12 text-center border border-nude/20 rounded-2xl py-6 px-8 max-w-md mx-auto">
        <p class="text-[10px] tracking-[0.2em] uppercase text-gold mb-2">Cancellation Policy</p>
        <p class="text-xs text-rich-black/40 max-w-md mx-auto leading-relaxed">
          We require 24 hours notice for cancellations or rescheduling. Late cancellations may incur a 50% service fee.
        </p>
      </div>

    </div>
  </section>

  <!-- SECTION 4 — Visit the Salon -->
  <section class="py-24 bg-blush relative overflow-hidden crosshatch">
    <span class="watermark bottom-0 right-0 opacity-[0.02]">Visit</span>
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-12">
        <div>
          <span class="inline-flex items-center gap-2 mb-4">
            <span class="w-8 h-px bg-gold"></span>
            <span class="text-xs tracking-[0.3em] uppercase text-gold font-medium">Find Us</span>
          </span>
          <h2 class="font-serif text-4xl font-light tracking-wide mb-8">Visit the Salon</h2>
          <div class="space-y-6">
            <div class="flex items-start gap-4">
              <div class="w-10 h-10 rounded-full bg-gold/10 flex items-center justify-center flex-shrink-0 mt-0.5">
                <svg class="w-4 h-4 text-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
              </div>
              <div>
                <p class="font-medium mb-1">45 York Street, Sydney NSW 2000</p>
              </div>
            </div>
            <div class="flex items-start gap-4">
              <div class="w-10 h-10 rounded-full bg-gold/10 flex items-center justify-center flex-shrink-0 mt-0.5">
                <svg class="w-4 h-4 text-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
              </div>
              <div>
                <a href="tel:0295556100" class="font-medium hover:text-gold transition-colors duration-300">02 9555 6100</a>
              </div>
            </div>
            <div class="flex items-start gap-4">
              <div class="w-10 h-10 rounded-full bg-gold/10 flex items-center justify-center flex-shrink-0 mt-0.5">
                <svg class="w-4 h-4 text-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
              </div>
              <div>
                <a href="mailto:hello@lumahairbeauty.com.au" class="font-medium hover:text-gold transition-colors duration-300">hello@lumahairbeauty.com.au</a>
              </div>
            </div>
            <div class="flex items-start gap-4">
              <div class="w-10 h-10 rounded-full bg-gold/10 flex items-center justify-center flex-shrink-0 mt-0.5">
                <svg class="w-4 h-4 text-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
              </div>
              <div class="text-sm space-y-1">
                <p><span class="font-medium">Tue – Wed:</span> <span class="text-rich-black/50">9am – 6pm</span></p>
                <p><span class="font-medium">Thu – Fri:</span> <span class="text-rich-black/50">9am – 8pm</span></p>
                <p><span class="font-medium">Saturday:</span> <span class="text-rich-black/50">8am – 5pm</span></p>
                <p><span class="font-medium">Sun – Mon:</span> <span class="text-rich-black/50">Closed</span></p>
              </div>
            </div>
            <div class="flex items-start gap-4">
              <div class="w-10 h-10 rounded-full bg-gold/10 flex items-center justify-center flex-shrink-0 mt-0.5">
                <svg class="w-4 h-4 text-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
              </div>
              <div class="text-sm text-rich-black/50">
                <p>We're on York Street between King and Market, ground floor. Look for the gold LUMA sign. Nearest stations: Wynyard (3 min walk) or Town Hall (5 min walk). Parking available at Westfield Sydney.</p>
              </div>
            </div>
          </div>
        </div>
        <div class="rounded-3xl overflow-hidden shadow-lg h-[400px] lg:h-full min-h-[400px] corner-brackets">
          <iframe
