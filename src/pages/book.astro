---
import Layout from '../layouts/Layout.astro';

const categories = [
  { id: 'hair', name: 'Hair', icon: '✂️', desc: 'Cuts, colour, treatments & extensions' },
  { id: 'skin', name: 'Skin', icon: '✨', desc: 'Facials, peels & skin therapy' },
  { id: 'nails', name: 'Nails', icon: '💅', desc: 'Manicures, pedicures & nail art' },
  { id: 'lashes', name: 'Lashes & Brows', icon: '👁️', desc: 'Extensions, lifts, tints & shaping' },
];

const stylists = [
  { name: 'Isabella Ferraro', role: 'Creative Director', image: 'https://images.unsplash.com/photo-1580618672591-eb180b1a973f?w=300&h=375&fit=crop', alt: 'Isabella Ferraro, Creative Director at LUMA' },
  { name: 'Aiden Park', role: 'Senior Colourist', image: 'https://images.unsplash.com/photo-1506794778202-cad84cf45f1d?w=300&h=375&fit=crop', alt: 'Aiden Park, Senior Colourist at LUMA' },
  { name: 'Chloe Bennett', role: 'Extensions Specialist', image: 'https://images.unsplash.com/photo-1534528741775-53994a69daeb?w=300&h=375&fit=crop', alt: 'Chloe Bennett, Extensions Specialist at LUMA' },
  { name: 'Maya Singh', role: 'Skin Therapist', image: 'https://images.unsplash.com/photo-1573497019940-1c28c88b4f3e?w=300&h=375&fit=crop', alt: 'Maya Singh, Skin Therapist at LUMA' },
];

const timeSlots = ['9:00 AM', '9:30 AM', '10:00 AM', '10:30 AM', '11:00 AM', '11:30 AM', '12:00 PM', '1:00 PM', '1:30 PM', '2:00 PM', '2:30 PM', '3:00 PM', '3:30 PM', '4:00 PM'];

const weekDays = [
  { day: 'Tue', date: '11', month: 'Mar' },
  { day: 'Wed', date: '12', month: 'Mar' },
  { day: 'Thu', date: '13', month: 'Mar' },
  { day: 'Fri', date: '14', month: 'Mar' },
  { day: 'Sat', date: '15', month: 'Mar' },
];

const instagramImages = [
  { src: 'https://images.unsplash.com/photo-1595476108010-b4d1f102b1b1?w=400&h=400&fit=crop', alt: 'Gorgeous wavy hair result at LUMA salon' },
  { src: 'https://images.unsplash.com/photo-1633681926022-84c23e8cb2d6?w=400&h=400&fit=crop', alt: 'LUMA salon warm interior shot' },
  { src: 'https://images.unsplash.com/photo-1495474472287-4d71bcdd2085?w=400&h=400&fit=crop', alt: 'Latte art from the LUMA salon coffee bar' },
  { src: 'https://images.unsplash.com/photo-1487412912498-0447578fcca8?w=400&h=400&fit=crop', alt: 'Behind the scenes styling at LUMA' },
];
---

<Layout title="Book Your Visit — LUMA Hair & Beauty">

  <!-- Page Header -->
  <section class="pt-16 pb-12 bg-warm-white">
    <div class="max-w-4xl mx-auto px-6 lg:px-8 text-center">
      <span class="inline-flex items-center gap-2 mb-6">
        <span class="w-8 h-px bg-gold"></span>
        <span class="text-xs tracking-[0.3em] uppercase text-gold font-medium">Appointments</span>
        <span class="w-8 h-px bg-gold"></span>
      </span>
      <h1 class="font-serif text-5xl sm:text-6xl font-light tracking-wide mb-6">Book Your Visit</h1>
      <p class="text-rich-black/60 max-w-xl mx-auto leading-relaxed">
        Choose your service, pick your stylist, and find a time that works. We'll confirm your appointment within the hour.
      </p>
    </div>
  </section>

  <!-- Booking Flow -->
  <section class="pb-24 bg-warm-white overflow-hidden">
    <div class="max-w-4xl mx-auto px-6 lg:px-8 overflow-hidden">
      <!-- Progress Bar -->
      <div class="flex items-center justify-between mb-12 max-w-lg mx-auto">
        {[1, 2, 3, 4].map((step) => (
          <div class="flex items-center">
            <div class={`booking-dot w-10 h-10 rounded-full flex items-center justify-center text-sm font-semibold transition-all duration-300 ${step === 1 ? 'bg-gold text-white' : 'bg-nude/30 text-rich-black/40'}`} data-step={step}>
              {step}
            </div>
            {step < 4 && <div class={`booking-line w-16 sm:w-24 h-0.5 mx-2 transition-colors duration-300 ${step === 1 ? 'bg-gold' : 'bg-nude/30'}`} data-line={step}></div>}
          </div>
        ))}
      </div>

      <!-- Steps Container -->
      <div id="booking-steps" class="relative min-h-[400px]">

        <!-- Step 1: Select Service -->
        <div class="booking-step active" data-booking-step="1">
          <h2 class="font-serif text-2xl text-center mb-2">Select Service</h2>
          <p class="text-sm text-center text-rich-black/50 mb-8">What would you like today?</p>
          <div class="grid sm:grid-cols-2 gap-4 max-w-2xl mx-auto">
            {categories.map((cat) => (
              <button class="service-card group text-left p-6 rounded-3xl border-2 border-nude/30 hover:border-gold bg-white/50 transition-all duration-300" data-service={cat.id}>
                <span class="text-3xl mb-3 block">{cat.icon}</span>
                <h3 class="font-serif text-xl mb-1">{cat.name}</h3>
                <p class="text-xs text-rich-black/50">{cat.desc}</p>
              </button>
            ))}
          </div>
        </div>

        <!-- Step 2: Select Stylist -->
        <div class="booking-step" data-booking-step="2">
          <h2 class="font-serif text-2xl text-center mb-2">Select Stylist</h2>
          <p class="text-sm text-center text-rich-black/50 mb-8">Choose your preferred stylist</p>
          <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 max-w-2xl mx-auto">
            {stylists.map((stylist) => (
              <button class="stylist-card group text-center p-4 rounded-3xl border-2 border-nude/30 hover:border-gold bg-white/50 transition-all duration-300" data-stylist={stylist.name}>
                <img src={stylist.image} alt={stylist.alt} class="w-20 h-20 rounded-full mx-auto mb-3 object-cover" loading="lazy" />
                <h3 class="font-serif text-sm">{stylist.name}</h3>
                <p class="text-xs text-rich-black/40">{stylist.role}</p>
              </button>
            ))}
          </div>
        </div>

        <!-- Step 3: Date & Time -->
        <div class="booking-step" data-booking-step="3">
          <h2 class="font-serif text-2xl text-center mb-2">Select Date & Time</h2>
          <p class="text-sm text-center text-rich-black/50 mb-8">Find a time that works for you</p>
          <div class="max-w-2xl mx-auto">
            <!-- Week View -->
            <div class="flex flex-wrap gap-3 mb-8 justify-center">
              {weekDays.map((d, i) => (
                <button class={`date-card flex flex-col items-center px-4 py-3 rounded-2xl border-2 transition-all duration-300 ${i === 0 ? 'border-gold bg-gold/10' : 'border-nude/30 bg-white/50 hover:border-gold'}`} data-date={d.date}>
                  <span class="text-xs text-rich-black/40 uppercase">{d.day}</span>
                  <span class="text-xl font-serif">{d.date}</span>
                  <span class="text-xs text-rich-black/40">{d.month}</span>
                </button>
              ))}
            </div>
            <!-- Time Slots -->
            <div class="grid grid-cols-3 sm:grid-cols-5 gap-2">
              {timeSlots.map((time, i) => (
                <button class={`time-card px-3 py-2.5 rounded-xl border text-sm transition-all duration-300 ${i === 4 ? 'border-gold bg-gold/10 text-rich-black' : 'border-nude/30 bg-white/50 hover:border-gold text-rich-black/70'}`} data-time={time}>
                  {time}
                </button>
              ))}
            </div>
            <div class="text-center mt-8">
              <button id="step3-next" class="px-8 py-3.5 bg-rich-black text-warm-white text-xs tracking-[0.2em] uppercase font-semibold rounded-full hover:shadow-[0_0_24px_rgba(212,168,83,0.4)] transition-all duration-300">
                Continue
              </button>
            </div>
          </div>
        </div>

        <!-- Step 4: Your Details -->
        <div class="booking-step" data-booking-step="4">
          <h2 class="font-serif text-2xl text-center mb-2">Your Details</h2>
          <p class="text-sm text-center text-rich-black/50 mb-8">Almost there — tell us how to reach you</p>
          <form id="booking-form" action="https://formspree.io/f/placeholder" method="POST" class="max-w-lg mx-auto space-y-4">
            <div>
              <label for="booking-name" class="block text-xs tracking-wider uppercase text-rich-black/50 mb-1.5">Full Name</label>
              <input type="text" id="booking-name" name="name" required class="w-full px-5 py-3 border border-nude/50 rounded-2xl text-sm focus:outline-none focus:border-gold transition-colors duration-300 bg-white/50" placeholder="Your name" />
            </div>
            <div>
              <label for="booking-email" class="block text-xs tracking-wider uppercase text-rich-black/50 mb-1.5">Email</label>
              <input type="email" id="booking-email" name="email" required class="w-full px-5 py-3 border border-nude/50 rounded-2xl text-sm focus:outline-none focus:border-gold transition-colors duration-300 bg-white/50" placeholder="you@example.com" />
            </div>
            <div>
              <label for="booking-phone" class="block text-xs tracking-wider uppercase text-rich-black/50 mb-1.5">Phone</label>
              <input type="tel" id="booking-phone" name="phone" required class="w-full px-5 py-3 border border-nude/50 rounded-2xl text-sm focus:outline-none focus:border-gold transition-colors duration-300 bg-white/50" placeholder="04XX XXX XXX" />
            </div>
            <div>
              <label for="booking-notes" class="block text-xs tracking-wider uppercase text-rich-black/50 mb-1.5">Notes (optional)</label>
              <textarea id="booking-notes" name="notes" rows="3" class="w-full px-5 py-3 border border-nude/50 rounded-2xl text-sm focus:outline-none focus:border-gold transition-colors duration-300 bg-white/50 resize-none" placeholder="Anything we should know?"></textarea>
            </div>
            <input type="hidden" name="service" id="hidden-service" />
            <input type="hidden" name="stylist" id="hidden-stylist" />
            <input type="hidden" name="date" id="hidden-date" />
            <input type="hidden" name="time" id="hidden-time" />
            <button type="submit" class="w-full py-4 bg-gold text-white text-xs tracking-[0.2em] uppercase font-semibold rounded-full hover:bg-gold/90 transition-colors duration-300 mt-4">
              Confirm Booking
            </button>
          </form>
        </div>

      </div>

      <!-- Cancellation Policy -->
      <div class="mt-12 text-center">
        <p class="text-xs text-rich-black/40 max-w-md mx-auto leading-relaxed">
          We require 24 hours notice for cancellations or rescheduling. Late cancellations may incur a 50% service fee.
        </p>
      </div>
    </div>
  </section>

  <!-- Contact Section -->
  <section id="contact" class="py-24 bg-blush">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-12">
        <!-- Contact Info -->
        <div>
          <span class="inline-flex items-center gap-2 mb-4">
            <span class="w-8 h-px bg-gold"></span>
            <span class="text-xs tracking-[0.3em] uppercase text-gold font-medium">Find Us</span>
          </span>
          <h2 class="font-serif text-4xl font-light tracking-wide mb-8">Visit the Salon</h2>

          <div class="space-y-6">
            <div class="flex items-start gap-4">
              <div class="w-10 h-10 rounded-full bg-gold/10 flex items-center justify-center flex-shrink-0 mt-0.5">
                <svg class="w-4 h-4 text-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
              </div>
              <div>
                <p class="font-medium mb-1">45 York Street, Sydney NSW 2000</p>
                <p class="text-sm text-rich-black/50">We're on York Street between King and Market, ground floor. Look for the gold LUMA sign.</p>
              </div>
            </div>

            <div class="flex items-start gap-4">
              <div class="w-10 h-10 rounded-full bg-gold/10 flex items-center justify-center flex-shrink-0 mt-0.5">
                <svg class="w-4 h-4 text-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
              </div>
              <div>
                <a href="tel:0295556100" class="font-medium hover:text-gold transition-colors duration-300">02 9555 6100</a>
              </div>
            </div>

            <div class="flex items-start gap-4">
              <div class="w-10 h-10 rounded-full bg-gold/10 flex items-center justify-center flex-shrink-0 mt-0.5">
                <svg class="w-4 h-4 text-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
              </div>
              <div>
                <a href="mailto:hello@lumahairbeauty.com.au" class="font-medium hover:text-gold transition-colors duration-300">hello@lumahairbeauty.com.au</a>
              </div>
            </div>

            <div class="flex items-start gap-4">
              <div class="w-10 h-10 rounded-full bg-gold/10 flex items-center justify-center flex-shrink-0 mt-0.5">
                <svg class="w-4 h-4 text-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
              </div>
              <div class="text-sm space-y-1">
                <p><span class="font-medium">Tue – Wed:</span> <span class="text-rich-black/50">9am – 6pm</span></p>
                <p><span class="font-medium">Thu – Fri:</span> <span class="text-rich-black/50">9am – 8pm</span></p>
                <p><span class="font-medium">Saturday:</span> <span class="text-rich-black/50">8am – 5pm</span></p>
                <p><span class="font-medium">Sun – Mon:</span> <span class="text-rich-black/50">Closed</span></p>
              </div>
            </div>

            <div class="flex items-start gap-4">
              <div class="w-10 h-10 rounded-full bg-gold/10 flex items-center justify-center flex-shrink-0 mt-0.5">
                <svg class="w-4 h-4 text-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
              </div>
              <div class="text-sm text-rich-black/50">
                <p>Nearest stations: Wynyard (3 min walk) or Town Hall (5 min walk). Parking available at Westfield Sydney.</p>
              </div>
            </div>
          </div>
        </div>

        <!-- Map -->
        <div class="rounded-3xl overflow-hidden shadow-lg h-[400px] lg:h-full min-h-[400px]">
          <iframe
            src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3312.8!2d151.206!3d-33.868!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x6b12ae3f3b312871%3A0x5017d681632ccc0!2s45%20York%20St%2C%20Sydney%20NSW%202000!5e0!3m2!1sen!2sau!4v1"
            width="100%"
            height="100%"
            style="border:0;"
            allowfullscreen=""
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            title="LUMA Hair & Beauty location on Google Maps"
          ></iframe>
        </div>
      </div>
    </div>
  </section>

  <!-- Social / Instagram -->
  <section class="py-20 bg-warm-white">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="text-center mb-10">
        <h2 class="font-serif text-3xl font-light tracking-wide mb-2">Follow Us for Daily Inspiration</h2>
        <a href="#" class="inline-flex items-center gap-2 text-rose hover:text-gold transition-colors duration-300">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
          <span class="text-sm font-medium">@lumahairbeauty</span>
        </a>
      </div>
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
        {instagramImages.map((img) => (
          <a href="#" class="group relative rounded-2xl overflow-hidden aspect-square">
            <img src={img.src} alt={img.alt} class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110" loading="lazy" />
            <div class="absolute inset-0 bg-rich-black/0 group-hover:bg-rich-black/30 transition-colors duration-300 flex items-center justify-center">
              <svg class="w-6 h-6 text-white opacity-0 group-hover:opacity-100 transition-opacity duration-300" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

</Layout>

<script>
  let currentStep = 1;
  let selectedService = '';
  let selectedStylist = '';

  function updateStep(step: number) {
    currentStep = step;

    // Update progress dots and lines
    document.querySelectorAll('.booking-dot').forEach((dot) => {
      const s = parseInt((dot as HTMLElement).dataset.step || '0');
      if (s <= step) {
        dot.classList.remove('bg-nude/30', 'text-rich-black/40');
        dot.classList.add('bg-gold', 'text-white');
      } else {
        dot.classList.add('bg-nude/30', 'text-rich-black/40');
        dot.classList.remove('bg-gold', 'text-white');
      }
    });

    document.querySelectorAll('.booking-line').forEach((line) => {
      const s = parseInt((line as HTMLElement).dataset.line || '0');
      if (s < step) {
        line.classList.remove('bg-nude/30');
        line.classList.add('bg-gold');
      } else {
        line.classList.add('bg-nude/30');
        line.classList.remove('bg-gold');
      }
    });

    // Show active step
    document.querySelectorAll('.booking-step').forEach((el) => {
      const s = parseInt((el as HTMLElement).dataset.bookingStep || '0');
      if (s === step) {
        el.classList.add('active');
      } else {
        el.classList.remove('active');
      }
    });
  }

  // Step 1: Service selection
  document.querySelectorAll('.service-card').forEach((card) => {
    card.addEventListener('click', () => {
      document.querySelectorAll('.service-card').forEach((c) => c.classList.remove('border-gold', 'bg-gold/5'));
      card.classList.add('border-gold', 'bg-gold/5');
      selectedService = (card as HTMLElement).dataset.service || '';
      (document.getElementById('hidden-service') as HTMLInputElement).value = selectedService;
      setTimeout(() => updateStep(2), 300);
    });
  });

  // Step 2: Stylist selection
  document.querySelectorAll('.stylist-card').forEach((card) => {
    card.addEventListener('click', () => {
      document.querySelectorAll('.stylist-card').forEach((c) => c.classList.remove('border-gold', 'bg-gold/5'));
      card.classList.add('border-gold', 'bg-gold/5');
      selectedStylist = (card as HTMLElement).dataset.stylist || '';
      (document.getElementById('hidden-stylist') as HTMLInputElement).value = selectedStylist;
      setTimeout(() => updateStep(3), 300);
    });
  });

  // Step 3: Date selection
  document.querySelectorAll('.date-card').forEach((card) => {
    card.addEventListener('click', () => {
      document.querySelectorAll('.date-card').forEach((c) => {
        c.classList.remove('border-gold', 'bg-gold/10');
        c.classList.add('border-nude/30', 'bg-white/50');
      });
      card.classList.add('border-gold', 'bg-gold/10');
      card.classList.remove('border-nude/30', 'bg-white/50');
      (document.getElementById('hidden-date') as HTMLInputElement).value = (card as HTMLElement).dataset.date || '';
    });
  });

  // Step 3: Time selection
  document.querySelectorAll('.time-card').forEach((card) => {
    card.addEventListener('click', () => {
      document.querySelectorAll('.time-card').forEach((c) => {
        c.classList.remove('border-gold', 'bg-gold/10');
        c.classList.add('border-nude/30', 'bg-white/50');
      });
      card.classList.add('border-gold', 'bg-gold/10');
      card.classList.remove('border-nude/30', 'bg-white/50');
      (document.getElementById('hidden-time') as HTMLInputElement).value = (card as HTMLElement).dataset.time || '';
    });
  });

  // Step 3: Continue button
  document.getElementById('step3-next')?.addEventListener('click', () => {
    updateStep(4);
  });

  // Form validation
  const form = document.getElementById('booking-form') as HTMLFormElement;
  form?.addEventListener('submit', (e) => {
    const name = (document.getElementById('booking-name') as HTMLInputElement).value.trim();
    const email = (document.getElementById('booking-email') as HTMLInputElement).value.trim();
    const phone = (document.getElementById('booking-phone') as HTMLInputElement).value.trim();
    if (!name || !email || !phone) {
      e.preventDefault();
      alert('Please fill in all required fields.');
    }
  });
</script>
