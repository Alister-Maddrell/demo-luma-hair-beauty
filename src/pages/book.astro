<script is:inline>
document.addEventListener('DOMContentLoaded', function () {
  var currentStep = 1;

  var step1 = document.getElementById('step-1');
  var step2 = document.getElementById('step-2');
  var step3 = document.getElementById('step-3');
  var step4 = document.getElementById('step-4');
  var steps = [step1, step2, step3, step4];

  var dots = document.querySelectorAll('.booking-dot');
  var lines = document.querySelectorAll('.booking-line');

  function goToStep(step) {
    currentStep = step;

    // Hide all steps, show the target
    for (var i = 0; i < steps.length; i++) {
      steps[i].style.display = (i === step - 1) ? 'block' : 'none';
    }

    // Update progress dots
    dots.forEach(function (dot) {
      var s = parseInt(dot.getAttribute('data-dot'));
      if (s <= step) {
        dot.style.background = '#D4A853';
        dot.style.color = '#fff';
      } else {
        dot.style.background = 'rgba(213, 196, 181, 0.3)';
        dot.style.color = 'rgba(26, 26, 26, 0.4)';
      }
    });

    // Update progress lines
    lines.forEach(function (line) {
      var s = parseInt(line.getAttribute('data-line'));
      line.style.background = (s < step) ? '#D4A853' : 'rgba(213, 196, 181, 0.3)';
    });

    // Scroll booking section into view
    document.getElementById('booking-section').scrollIntoView({ behavior: 'smooth', block: 'start' });
  }

  // Step 1: Service cards
  var serviceCards = document.querySelectorAll('.service-card');
  serviceCards.forEach(function (card) {
    card.addEventListener('click', function () {
      serviceCards.forEach(function (c) {
        c.style.borderColor = '';
        c.style.background = '';
      });
      card.style.borderColor = '#D4A853';
      card.style.background = 'rgba(212, 168, 83, 0.05)';
      document.getElementById('hidden-service').value = card.getAttribute('data-service');
      setTimeout(function () { goToStep(2); }, 400);
    });
  });

  // Step 2: Stylist cards
  var stylistCards = document.querySelectorAll('.stylist-card');
  stylistCards.forEach(function (card) {
    card.addEventListener('click', function () {
      stylistCards.forEach(function (c) {
        c.style.borderColor = '';
        c.style.background = '';
      });
      card.style.borderColor = '#D4A853';
      card.style.background = 'rgba(212, 168, 83, 0.05)';
      document.getElementById('hidden-stylist').value = card.getAttribute('data-stylist');
      setTimeout(function () { goToStep(3); }, 400);
    });
  });

  // Step 3: Time slots
  var timeSlots = document.querySelectorAll('.time-slot');
  timeSlots.forEach(function (btn) {
    btn.addEventListener('click', function () {
      timeSlots.forEach(function (b) {
        b.style.borderColor = '';
        b.style.background = '';
        b.style.color = '';
      });
      btn.style.borderColor = '#D4A853';
      btn.style.background = 'rgba(212, 168, 83, 0.1)';
      btn.style.color = '#1A1A1A';
      document.getElementById('hidden-time').value = btn.getAttribute('data-time');
      setTimeout(function () { goToStep(4); }, 400);
    });
  });

  // Back links
  var backLinks = document.querySelectorAll('.back-link');
  backLinks.forEach(function (link) {
    link.addEventListener('click', function () {
      goToStep(currentStep - 1);
    });
  });

  // Form submission
  var form = document.getElementById('booking-form');
  form.addEventListener('submit', function (e) {
    e.preventDefault();
    form.style.display = 'none';
    document.getElementById('success-message').style.display = 'block';
    // Hide back link and headings on success
    var step4El = document.getElementById('step-4');
    var backBtn = step4El.querySelector('.back-link');
    if (backBtn) backBtn.style.display = 'none';
    step4El.querySelector('h2').style.display = 'none';
    step4El.querySelector('p').style.display = 'none';
  });
});
</script>
