      { name: 'Signature Facial (60 min)', desc: 'Full treatment customised to your skin type and concerns', price: '$150' },
      { name: 'Advanced Peel', desc: 'Clinical-grade chemical peel for resurfacing and renewal', price: 'from $180' },
      { name: 'LED Light Therapy', desc: 'Add-on or standalone treatment for acne, redness, or rejuvenation', price: '$60' },
      { name: 'Microdermabrasion', desc: 'Mechanical exfoliation for smoother, brighter skin', price: '$140' },
