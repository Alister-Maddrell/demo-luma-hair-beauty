---

<Layout title="Hair & Beauty Services Sydney CBD | LUMA Pricing" description="Explore 40+ hair, skin, nail and beauty services at LUMA Sydney CBD. View our full menu with transparent pricing. Book your visit online today.">

  <!-- Page Header — Dramatic editorial hero -->
  <section class="relative pt-32 pb-20 bg-ink overflow-hidden">
    <span class="watermark -top-8 right-0 text-paper">Menu</span>
    <div class="max-w-[1400px] mx-auto px-6 lg:px-10 text-center relative">
      <div class="inline-flex items-center gap-2 bg-hot-pink text-paper text-[9px] tracking-[0.3em] uppercase font-bold px-4 py-2 mb-8">6 Categories · 40+ Services</div>
      <span class="flex items-center justify-center gap-3 mb-6">
        <span class="w-10 h-[2px] bg-hot-pink"></span>
        <span class="text-[10px] tracking-[0.4em] uppercase text-hot-pink font-bold">Full Menu</span>
        <span class="w-10 h-[2px] bg-hot-pink"></span>
      </span>
      <h1 class="font-display text-5xl sm:text-7xl lg:text-8xl font-bold tracking-tight text-paper leading-[0.95] mb-8">Services<br />&amp; Pricing</h1>
      <div class="w-16 h-[2px] bg-hot-pink mx-auto mb-8"></div>
      <p class="text-paper/50 max-w-xl mx-auto leading-relaxed">
        Find the perfect treatment for you. All prices are starting from — your stylist will tailor a personalised quote during your complimentary consultation.
      </p>
    </div>
  </section>

  <!-- Service Categories — High contrast accordion -->
  <section class="py-20 lg:py-28 bg-paper relative overflow-hidden">
    <div class="max-w-4xl mx-auto px-6 lg:px-10 relative">
      <div class="space-y-3">
        {serviceCategories.map((category, i) => (
          <div class="service-category border-2 border-ink/10 overflow-hidden bg-paper hover:border-ink/20 transition-colors duration-300">
            <button
              class="service-toggle w-full flex items-center justify-between px-8 py-6 text-left hover:bg-blush/50 transition-colors duration-300"
              data-target={category.id}
              aria-expanded="false"
            >
              <div class="flex items-center gap-4">
                <span class="text-[10px] text-hot-pink font-bold tracking-wider hidden sm:inline">0{i + 1}</span>
                <h2 class="font-display text-xl sm:text-2xl font-bold tracking-tight">{category.title}</h2>
              </div>
              <div class="flex items-center gap-4">
                <span class="text-[10px] text-ink/30 tracking-[0.2em] uppercase font-semibold hidden sm:block">{category.services.length} services</span>
                <svg class="service-chevron w-5 h-5 text-hot-pink transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                </svg>
              </div>
            </button>
            <div id={category.id} class="service-content">
              <div>
                <div class="px-8 pb-8">
                  <div class="pt-4 space-y-0">
                    {category.services.map((service, j) => (
                      <div class="py-3 border-b border-ink/5 last:border-0">
                        <div class="flex items-baseline justify-between">
                          <h3 class="font-semibold text-sm">{service.name}</h3>
                          <span class="text-sm font-display font-bold text-hot-pink whitespace-nowrap ml-4">{service.price}</span>
                        </div>
                        <p class="text-xs text-ink/40 mt-1">{service.desc}</p>
                      </div>
                    ))}
                  </div>
                </div>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Consultation CTA — Bold dark section -->
  <section class="py-24 lg:py-32 bg-ink relative overflow-hidden">
    <span class="watermark -top-4 right-0 text-paper">Book</span>
    <div class="max-w-2xl mx-auto px-6 lg:px-10 text-center relative">
      <div class="inline-flex items-center bg-hot-pink text-paper text-[9px] tracking-[0.3em] uppercase font-bold px-4 py-2 mb-6">Complimentary</div>
      <h2 class="font-display text-4xl sm:text-5xl font-bold tracking-tight text-paper mb-4">Not Sure Where<br />to Start?</h2>
      <p class="text-paper/50 mb-10 leading-relaxed max-w-lg mx-auto">
        Every visit begins with a complimentary consultation. Share your goals with us, and we will create a personalised plan to help you look and feel your absolute best.
      </p>
      <a href="/book" class="btn-primary">
        Book Your Free Consultation
      </a>
      <p class="text-[10px] text-paper/30 mt-6 tracking-wider uppercase">No obligation · Takes 15 minutes · In-salon or virtual</p>
    </div>
  </section>

  <!-- Products We Love — Light section with dark cards -->
  <section class="py-24 lg:py-32 bg-blush relative overflow-hidden">
    <span class="watermark -top-4 right-0">Products</span>
    <div class="max-w-[1400px] mx-auto px-6 lg:px-10 relative">
      <div class="text-center mb-16">
        <span class="inline-flex items-center justify-center gap-3 mb-4">
          <span class="w-10 h-[2px] bg-hot-pink"></span>
          <span class="text-[10px] tracking-[0.4em] uppercase text-hot-pink font-bold">In the Studio</span>
          <span class="w-10 h-[2px] bg-hot-pink"></span>
        </span>
        <h2 class="font-display text-4xl sm:text-5xl font-bold tracking-tight mb-4">Products We Love</h2>
        <div class="w-12 h-[2px] bg-hot-pink mx-auto mb-6"></div>
        <p class="text-ink/50">Your results deserve the best — we only use and stock professional-grade products from brands we trust.</p>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-5">
        {products.map((product) => (
          <div class="group bg-ink overflow-hidden card-editorial border border-champagne/20 hover:border-hot-pink/40">
            <div class="overflow-hidden relative">
              <img
                src={product.image}
                alt={product.alt}
                class="w-full h-48 object-cover transition-transform duration-700 group-hover:scale-105 grayscale group-hover:grayscale-0"
                loading="lazy"
              />
              <div class="absolute top-3 right-3 bg-champagne text-ink text-[8px] tracking-[0.3em] uppercase font-bold px-3 py-1.5">In Salon</div>
            </div>
            <div class="p-6">
              <h3 class="font-display text-xl text-paper font-bold mb-1">{product.name}</h3>
              <p class="text-sm text-paper/50">{product.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

</Layout>

<script>
  document.querySelectorAll('.service-toggle').forEach((btn) => {
    btn.addEventListener('click', () => {
      const targetId = (btn as HTMLElement).dataset.target;
      const content = document.getElementById(targetId!);
      const chevron = btn.querySelector('.service-chevron');
      const isOpen = content?.classList.contains('open');

      // Close all others
      document.querySelectorAll('.service-content').forEach((el) => el.classList.remove('open'));
      document.querySelectorAll('.service-chevron').forEach((el) => el.classList.remove('rotate-180'));
      document.querySelectorAll('.service-toggle').forEach((el) => el.setAttribute('aria-expanded', 'false'));

      if (!isOpen) {
        content?.classList.add('open');
        chevron?.classList.add('rotate-180');
        btn.setAttribute('aria-expanded', 'true');
      }
    });
  });
</script>
