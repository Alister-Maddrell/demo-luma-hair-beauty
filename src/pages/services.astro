      { name: 'Blowdry & Style', desc: 'Wash and professional blowdry or styled finish', price: 'from $65' },
      { name: 'Special Occasion Style', desc: 'Formal, bridal party, or event styling', price: 'from $120' },
      { name: 'Fringe Trim', desc: 'Quick trim between appointments', price: '$20' },
    ],
  },
  {
    id: 'hair-colour',
    title: 'Hair — Colour',
    services: [
      { name: 'Full Colour', desc: 'Root to tip single-process colour', price: 'from $150' },
      { name: 'Root Touch-Up', desc: 'Regrowth colour, same shade', price: 'from $110' },
      { name: 'Half Head Foils', desc: 'Partial highlights for dimension and brightness', price: 'from $180' },
      { name: 'Full Head Foils', desc: 'Complete highlight or lowlight service', price: 'from $250' },
      { name: 'Balayage / Ombré', desc: 'Hand-painted colour for a natural, lived-in finish', price: 'from $280' },
      { name: 'Colour Correction', desc: 'Complex colour fixes priced on consultation', price: 'from $350' },
      { name: 'Toner / Gloss', desc: 'Refresh tone and add shine between colour services', price: 'from $60' },
    ],
  },
  {
    id: 'hair-treatments',
    title: 'Hair — Treatments & Extensions',
    services: [
      { name: 'Olaplex Treatment', desc: 'Bond repair and strengthening, added to any service', price: '$45' },
      { name: 'Keratin Smoothing', desc: 'Anti-frizz treatment lasting 3-5 months', price: 'from $350' },
      { name: 'Scalp Treatment', desc: 'Detox, hydrate, and balance your scalp', price: 'from $60' },
      { name: 'Tape Extensions', desc: 'Natural-looking volume and length, per pack', price: 'from $350' },
      { name: 'Micro-Link Extensions', desc: 'Individual strand application for seamless blending', price: 'from $500' },
      { name: 'Extension Maintenance', desc: 'Move-up, tighten, and restyle', price: 'from $150' },
    ],
